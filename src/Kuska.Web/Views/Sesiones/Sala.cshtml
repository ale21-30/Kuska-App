@model Kuska.Core.Entities.Sesion
@{
    ViewData["Title"] = "Sala Supervisada";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-between" style="margin-bottom:1.5rem">
    <div>
        <div class="section-label">Sesión en vivo</div>
        <div class="section-title">Sala <em>supervisada</em></div>
        <div class="section-sub">Videollamada segura — máx. 3 personas, tutor presente siempre 🔒</div>
    </div>
    <div style="display:flex;align-items:center;gap:0.7rem">
        <div style="display:flex;align-items:center;gap:0.4rem;background:#FEE2E2;border:1px solid #FCA5A5;border-radius:99px;padding:0.3rem 0.8rem">
            <div style="width:8px;height:8px;border-radius:50%;background:#EF4444;animation:pulse 1s infinite"></div>
            <span style="font-size:0.75rem;font-weight:700;color:#B91C1C">En vivo — Sesión #@Model.SesionId</span>
        </div>
        <span style="font-size:0.7rem;background:var(--green-pale);color:var(--green);border:1px solid #86EFAC;border-radius:99px;padding:0.28rem 0.75rem;font-weight:600">🔒 Cifrada</span>
    </div>
</div>

<div class="grid-2">
    <!-- COLUMNA IZQUIERDA: VIDEO + SEGURIDAD -->
    <div style="display:flex;flex-direction:column;gap:1rem">

        <!-- SALA DE VIDEO -->
        <div style="background:#1A0A2E;border:2px solid #7B2FA8;border-radius:18px;overflow:hidden">
            <div style="padding:0.7rem 1.1rem;background:#2D1B4E;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(196,181,253,0.2)">
                <span style="font-size:0.75rem;color:rgba(196,181,253,0.7)">Link único · Expira al finalizar</span>
                <span style="font-size:0.68rem;color:rgba(255,255,255,0.4)">@Model.LinkExpiracion?.ToString("HH:mm")</span>
            </div>

            <!-- Supervisora -->
            <div style="margin:0.7rem;background:rgba(21,128,61,0.2);border:1px solid rgba(134,239,172,0.4);border-radius:11px;padding:0.7rem 1rem;display:flex;align-items:center;gap:0.7rem">
                <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#16A34A,#4ADE80);display:flex;align-items:center;justify-content:center;color:white;font-size:0.62rem;font-weight:800">
                    @Model.Supervisora.Nombre.Substring(0, 2).ToUpper()
                </div>
                <div>
                    <div style="font-size:0.75rem;font-weight:700;color:#86EFAC">👁️ Supervisora presente — @Model.Supervisora.Nombre</div>
                    <div style="font-size:0.63rem;color:rgba(255,255,255,0.5)">Si se desconecta, la sesión se pausa automáticamente</div>
                </div>
            </div>

            <!-- Grid participantes -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;padding:0 0.7rem 0.7rem">
                <div style="background:#2D1B4E;border-radius:11px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem 1rem;border:1px solid rgba(196,181,253,0.15);position:relative;min-height:110px">
                    <div style="width:44px;height:44px;border-radius:50%;background:#3B0764;display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:1rem">
                        @Model.Nina.NombrePila.Substring(0, 1)
                    </div>
                    <div style="margin-top:0.4rem;font-size:0.7rem;color:rgba(255,255,255,0.6)">@Model.Nina.NombrePila · @Model.Nina.Edad años</div>
                    <div style="position:absolute;bottom:0.4rem;left:0.5rem;font-size:0.6rem;background:rgba(0,0,0,0.55);padding:0.15rem 0.45rem;border-radius:5px;color:white">Participante</div>
                </div>
                <div style="background:#2D1B4E;border-radius:11px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem 1rem;border:1px solid rgba(196,181,253,0.4);position:relative;min-height:110px">
                    <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#B45309,#F59E0B);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:1rem">
                        @Model.Mentora.Usuario.Nombre.Substring(0, 2).ToUpper()
                    </div>
                    <div style="margin-top:0.4rem;font-size:0.7rem;color:rgba(255,255,255,0.6)">@Model.Mentora.Usuario.Nombre</div>
                    <div style="position:absolute;bottom:0.4rem;left:0.5rem;font-size:0.6rem;background:rgba(91,26,138,0.7);padding:0.15rem 0.45rem;border-radius:5px;color:white">Mentora ✓</div>
                </div>
            </div>

            @if (Model.LinkSala != null)
            {
                <div style="padding:0 0.7rem 0.7rem">
                    <a href="@Model.LinkSala" target="_blank"
                       style="display:block;text-align:center;background:#5B1A8A;color:white;border-radius:11px;padding:0.65rem;font-size:0.82rem;font-weight:700;text-decoration:none">
                        🎥 Abrir videollamada →
                    </a>
                </div>
            }

            <!-- Controles -->
            <div style="padding:0.7rem 1.1rem;background:#2D1B4E;display:flex;align-items:center;justify-content:center;gap:0.7rem;border-top:1px solid rgba(196,181,253,0.2)">
                <div style="width:38px;height:38px;border-radius:50%;background:rgba(91,26,138,0.6);display:flex;align-items:center;justify-content:center;font-size:0.9rem">🎤</div>
                <div style="width:38px;height:38px;border-radius:50%;background:rgba(91,26,138,0.6);display:flex;align-items:center;justify-content:center;font-size:0.9rem">📷</div>

                <!-- Botón reporte -->
                <form method="post" asp-controller="Sesiones" asp-action="Reportar" style="display:inline">
                    <input type="hidden" name="sesionId" value="@Model.SesionId" />
                    <input type="hidden" name="descripcion" value="Reporte desde sala de videollamada" />
                    <button type="submit" onclick="return confirm('¿Estás segura de que quieres reportar esta sesión? Se cerrará inmediatamente.')"
                            style="width:38px;height:38px;border-radius:50%;background:rgba(245,158,11,0.3);border:none;cursor:pointer;font-size:0.9rem">
                        🚨
                    </button>
                </form>

                <a asp-controller="Mentorias" asp-action="MisSesiones"
                   style="width:48px;height:48px;border-radius:50%;background:#DC2626;display:flex;align-items:center;justify-content:center;font-size:0.9rem;text-decoration:none">📞</a>
            </div>
        </div>

        <!-- REGLAS DE SEGURIDAD -->
        <div class="card">
            <div class="card-title">Reglas de seguridad activas</div>
            <div style="display:flex;flex-direction:column;gap:0.3rem;margin-top:0.5rem">
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)">
                    <span>Máximo 3 participantes</span>
                    <span style="color:var(--green);font-weight:700">✓ Activo</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)">
                    <span>Pausa si tutor se desconecta</span>
                    <span style="color:var(--green);font-weight:700">✓ Activo</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)">
                    <span>Link único no reutilizable</span>
                    <span style="color:var(--green);font-weight:700">✓ Activo</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)">
                    <span>Duración máxima 60 minutos</span>
                    <span style="color:var(--green);font-weight:700">✓ Activo</span>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:0.4rem 0;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Grabación</span>
                    <span style="color:var(--ink-soft);font-weight:700">✗ Desactivada</span>
                </div>
            </div>
        </div>
    </div>

    <!-- COLUMNA DERECHA: DATOS + LOG -->
    <div style="display:flex;flex-direction:column;gap:1rem">

        <!-- DATOS DE LA SESIÓN -->
        <div class="card">
            <div class="card-title">Detalles de la sesión</div>
            <hr class="divider">
            <div style="display:flex;flex-direction:column;gap:0.5rem">
                <div style="display:flex;justify-content:space-between;font-size:0.82rem">
                    <span style="color:var(--ink-soft)">Tema</span>
                    <span style="font-weight:700">@Model.Tema</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.82rem">
                    <span style="color:var(--ink-soft)">Duración máxima</span>
                    <span style="font-weight:700">@Model.DuracionMinutos minutos</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.82rem">
                    <span style="color:var(--ink-soft)">Estado</span>
                    <span class="badge badge-green">@Model.Estado</span>
                </div>
            </div>
        </div>

        <!-- QUÉ VE LA MENTORA -->
        <div class="card">
            <div class="card-title">¿Qué puede ver la mentora?</div>
            <div class="card-sub">Protección de datos activa en todo momento</div>
            <hr class="divider">
            <div style="display:flex;flex-direction:column;gap:0.45rem">
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Nombre completo</span><span class="badge badge-red">🚫 Oculto</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Nombre de pila</span><span class="badge badge-green">✓ Visible</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Edad</span><span class="badge badge-green">✓ Visible</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Colegio / dirección</span><span class="badge badge-red">🚫 Oculto</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Datos financieros</span><span class="badge badge-red">🚫 Oculto</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.79rem;color:var(--ink-mid)">
                    <span>Área de interés</span><span class="badge badge-green">✓ Visible</span>
                </div>
            </div>
            <hr class="divider">
            <div class="info-box info-red" style="margin:0">
                🚨 Si algo te parece inapropiado presiona 🚨 — la sesión se cierra de inmediato y el equipo de Kuska recibe una alerta.
            </div>
        </div>

        <!-- LOG DE AUDITORÍA -->
        <div class="card">
            <div class="card-title">Registro de la sesión</div>
            <div class="card-sub">Log inmutable — guardado automáticamente</div>
            <div style="display:flex;flex-direction:column;gap:0.4rem;margin-top:0.5rem">
                <div style="display:flex;gap:0.7rem;padding:0.55rem 0.8rem;background:var(--green-pale);border-left:3px solid var(--green);border-radius:0 9px 9px 0">
                    <div style="font-size:0.79rem;color:var(--green);font-weight:600">✅ Sala generada — Link único activo</div>
                </div>
                <div style="display:flex;gap:0.7rem;padding:0.55rem 0.8rem;background:var(--cream);border-left:3px solid var(--purple);border-radius:0 9px 9px 0">
                    <div style="font-size:0.79rem;color:var(--ink-mid)">🔑 Expira: @Model.LinkExpiracion?.ToString("HH:mm") — máx. 90 minutos</div>
                </div>
                <div style="display:flex;gap:0.7rem;padding:0.55rem 0.8rem;background:var(--cream);border-left:3px solid var(--purple);border-radius:0 9px 9px 0">
                    <div style="font-size:0.79rem;color:var(--ink-mid)">📋 Supervisora: @Model.Supervisora.Nombre</div>
                </div>
                <div style="display:flex;gap:0.7rem;padding:0.55rem 0.8rem;background:var(--cream);border-left:3px solid var(--purple);border-radius:0 9px 9px 0">
                    <div style="font-size:0.79rem;color:var(--ink-mid)">✓ Mentora verificada con cédula</div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes pulse {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: 0.3
        }
    }
</style>