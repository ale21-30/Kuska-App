@model Kuska.Core.Entities.Sesion
@{
    ViewData["Title"] = "Sala Supervisada";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    @@keyframes pulse {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: 0.4
        }
    }
</style>

<div class="row-between" style="margin-bottom:1.2rem">
    <div>
        <div class="section-label">Sesión en vivo</div>
        <div class="section-title">Sala <em>supervisada</em></div>
    </div>
    <div style="display:flex;gap:0.5rem;align-items:center">
        <div style="display:flex;align-items:center;gap:0.4rem;background:#FEE2E2;border:1px solid #FCA5A5;border-radius:99px;padding:0.3rem 0.9rem">
            <div style="width:8px;height:8px;border-radius:50%;background:#EF4444;animation:pulse 1s infinite"></div>
            <span style="font-size:0.75rem;font-weight:700;color:#B91C1C">EN VIVO</span>
        </div>
        <span style="font-size:0.7rem;background:var(--green-pale);color:var(--green);border:1px solid #86EFAC;border-radius:99px;padding:0.28rem 0.75rem;font-weight:600">🔒 Cifrada</span>
        <span style="font-size:0.7rem;background:#F3EEFF;color:var(--purple);border:1px solid #D4B8F0;border-radius:99px;padding:0.28rem 0.75rem;font-weight:600">Sesión #@Model.SesionId</span>
    </div>
</div>

<div class="grid-2">

    <div style="display:flex;flex-direction:column;gap:1rem">

        <!-- SALA VIDEO -->
        <div style="background:#0F0520;border:2px solid #7B2FA8;border-radius:18px;overflow:hidden">

            <div style="padding:0.6rem 1rem;background:#1A0A2E;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(196,181,253,0.15)">
                <div style="display:flex;align-items:center;gap:0.5rem">
                    <div style="width:7px;height:7px;border-radius:50%;background:#EF4444;animation:pulse 1s infinite"></div>
                    <span style="font-size:0.68rem;color:rgba(196,181,253,0.6);font-family:monospace">kuska.sala/@Model.SesionId · expira en 58:32</span>
                </div>
                <span style="font-size:0.65rem;color:rgba(255,255,255,0.3)">max 3 · no grabable</span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;padding:0.8rem">
                <div style="background:linear-gradient(145deg,#1E0A3C,#2D1B4E);border-radius:12px;padding:1.5rem 1rem;display:flex;flex-direction:column;align-items:center;min-height:130px;border:1px solid rgba(196,181,253,0.1);position:relative">
                    <div style="font-size:2.2rem">👧</div>
                    <div style="font-size:0.72rem;color:rgba(255,255,255,0.7);margin-top:0.4rem;font-weight:600">@Model.Nina.NombrePila</div>
                    <div style="font-size:0.62rem;color:rgba(255,255,255,0.35)">@Model.Nina.Edad años</div>
                    <div style="position:absolute;bottom:0.5rem;left:0.5rem;background:rgba(0,0,0,0.5);border-radius:5px;padding:0.12rem 0.4rem;font-size:0.58rem;color:rgba(255,255,255,0.5)">Participante</div>
                    <div style="position:absolute;top:0.5rem;right:0.5rem;width:7px;height:7px;border-radius:50%;background:#22C55E"></div>
                </div>
                <div style="background:linear-gradient(145deg,#1E0A3C,#2D1B4E);border-radius:12px;padding:1.5rem 1rem;display:flex;flex-direction:column;align-items:center;min-height:130px;border:1px solid rgba(167,139,250,0.3);position:relative">
                    <div style="width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#7C3AED,#A78BFA);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:1rem">
                        @Model.Mentora.Usuario.Nombre.Substring(0, 2).ToUpper()
                    </div>
                    <div style="font-size:0.72rem;color:rgba(255,255,255,0.7);margin-top:0.4rem;font-weight:600">@Model.Mentora.Usuario.Nombre</div>
                    <div style="font-size:0.62rem;color:rgba(167,139,250,0.6)">✓ Verificada</div>
                    <div style="position:absolute;bottom:0.5rem;left:0.5rem;background:rgba(124,58,237,0.4);border-radius:5px;padding:0.12rem 0.4rem;font-size:0.58rem;color:#C4B5FD">Mentora</div>
                    <div style="position:absolute;top:0.5rem;right:0.5rem;width:7px;height:7px;border-radius:50%;background:#22C55E"></div>
                </div>
            </div>

            <div style="margin:0 0.8rem;background:rgba(21,128,61,0.15);border:1px solid rgba(134,239,172,0.3);border-radius:10px;padding:0.5rem 0.9rem;display:flex;align-items:center;gap:0.6rem">
                <div style="width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,#16A34A,#4ADE80);display:flex;align-items:center;justify-content:center;color:white;font-size:0.6rem;font-weight:800;flex-shrink:0">S</div>
                <div>
                    <div style="font-size:0.72rem;font-weight:700;color:#86EFAC">👁️ Supervisora presente — sesión activa</div>
                    <div style="font-size:0.6rem;color:rgba(255,255,255,0.4)">Si se desconecta, la sesión se pausa automáticamente</div>
                </div>
            </div>

            <div style="margin:0.6rem 0.8rem;padding:0.5rem 0.9rem;background:rgba(196,181,253,0.08);border-radius:8px;border-left:3px solid #7C3AED">
                <span style="font-size:0.68rem;color:rgba(196,181,253,0.5)">Tema:</span>
                <span style="font-size:0.75rem;color:rgba(255,255,255,0.7);margin-left:0.4rem;font-weight:600">@Model.Tema</span>
            </div>

            <div style="padding:0.8rem;background:#1A0A2E;display:flex;align-items:center;justify-content:center;gap:0.6rem;border-top:1px solid rgba(196,181,253,0.1);margin-top:0.6rem">
                <div style="width:40px;height:40px;border-radius:50%;background:rgba(124,58,237,0.4);display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer">🎤</div>
                <div style="width:40px;height:40px;border-radius:50%;background:rgba(124,58,237,0.4);display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer">📷</div>
                <div style="width:40px;height:40px;border-radius:50%;background:rgba(124,58,237,0.4);display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:pointer">💬</div>
                <form method="post" asp-controller="Sesiones" asp-action="Reportar" style="display:inline">
                    <input type="hidden" name="sesionId" value="@Model.SesionId" />
                    <input type="hidden" name="descripcion" value="Reporte desde sala" />
                    <button type="submit" onclick="return confirm('¿Reportar y cerrar la sesión?')"
                            style="width:40px;height:40px;border-radius:50%;background:rgba(245,158,11,0.3);border:1px solid rgba(245,158,11,0.4);cursor:pointer;font-size:1rem">
                        🚨
                    </button>
                </form>
                <a asp-controller="Mentorias" asp-action="MisSesiones"
                   style="width:48px;height:48px;border-radius:50%;background:#DC2626;display:flex;align-items:center;justify-content:center;font-size:1.1rem;text-decoration:none">📞</a>
            </div>
        </div>

        <!-- REGLAS -->
        <div class="card">
            <div class="card-title" style="font-size:0.85rem">Reglas de seguridad activas</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.3rem;margin-top:0.5rem">
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Máx. 3 participantes</span><span style="color:var(--green);font-weight:700">✓</span></div>
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Pausa si tutor se va</span><span style="color:var(--green);font-weight:700">✓</span></div>
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Link único</span><span style="color:var(--green);font-weight:700">✓</span></div>
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Sin grabación</span><span style="color:var(--green);font-weight:700">✓</span></div>
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Máx. 60 minutos</span><span style="color:var(--green);font-weight:700">✓</span></div>
                <div style="display:flex;justify-content:space-between;font-size:0.75rem;padding:0.3rem 0.5rem;background:var(--green-pale);border-radius:6px"><span>Cifrado E2E</span><span style="color:var(--green);font-weight:700">✓</span></div>
            </div>
        </div>
    </div>

    <!-- PANEL DERECHO -->
    <div style="display:flex;flex-direction:column;gap:1rem">

        <div class="card">
            <div class="card-title">Datos visibles para la mentora</div>
            <hr class="divider">
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)"><span>Nombre completo</span><span class="badge badge-red">🚫 Oculto</span></div>
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)"><span>Nombre de pila</span><span class="badge badge-green">✓ Visible</span></div>
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)"><span>Edad</span><span class="badge badge-green">✓ Visible</span></div>
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)"><span>Colegio / dirección</span><span class="badge badge-red">🚫 Oculto</span></div>
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.79rem;color:var(--ink-mid)"><span>Datos financieros</span><span class="badge badge-red">🚫 Oculto</span></div>
            <div style="display:flex;justify-content:space-between;padding:0.4rem 0;font-size:0.79rem;color:var(--ink-mid)"><span>Área de interés</span><span class="badge badge-green">✓ Visible</span></div>
            <div class="info-box info-red" style="margin-top:0.8rem;margin-bottom:0;font-size:0.75rem">
                🚨 Presiona 🚨 para cerrar la sala de inmediato y alertar al equipo Kuska.
            </div>
        </div>

        <div class="card">
            <div class="card-title">Registro de auditoría</div>
            <div class="card-sub">Log inmutable — guardado automáticamente</div>
            <div style="display:flex;flex-direction:column;gap:0.4rem;margin-top:0.6rem">
                <div style="padding:0.45rem 0.75rem;background:var(--green-pale);border-left:3px solid var(--green);border-radius:0 8px 8px 0;font-size:0.76rem;color:var(--green);font-weight:500">✅ Sala generada — link único activo</div>
                <div style="padding:0.45rem 0.75rem;background:var(--cream);border-left:3px solid var(--purple);border-radius:0 8px 8px 0;font-size:0.76rem;color:var(--purple);font-weight:500">🔑 Link expira en 90 minutos</div>
                <div style="padding:0.45rem 0.75rem;background:var(--cream);border-left:3px solid var(--ink-mid);border-radius:0 8px 8px 0;font-size:0.76rem;color:var(--ink-mid);font-weight:500">✓ Mentora verificada con cédula</div>
                <div style="padding:0.45rem 0.75rem;background:var(--cream);border-left:3px solid var(--ink-mid);border-radius:0 8px 8px 0;font-size:0.76rem;color:var(--ink-mid);font-weight:500">👁️ Supervisora conectada</div>
            </div>
        </div>

        <div class="card" style="background:linear-gradient(135deg,#F3EEFF,#FDFCFF);border-color:#D4B8F0">
            <div style="font-size:0.78rem;font-weight:700;color:var(--purple);margin-bottom:0.4rem">🛡️ Cumplimiento LOPDP Ecuador 2021</div>
            <div style="font-size:0.73rem;color:var(--ink-soft);line-height:1.5">
                Esta sala cumple con la Ley Orgánica de Protección de Datos Personales del Ecuador y el Código de la Niñez y Adolescencia. Los datos de la menor nunca son compartidos con terceros.
            </div>
        </div>
    </div>
</div>