@model IEnumerable<Kuska.Core.Entities.Sesion>
@{
    ViewData["Title"] = "Mis Sesiones";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-between" style="margin-bottom:1.8rem">
    <div>
        <div class="section-label">Módulo de Mentorías</div>
        <div class="section-title">Mis <em>sesiones</em></div>
        <div class="section-sub">Historial de mentorías agendadas y completadas 📅</div>
    </div>
    <a asp-action="Index" class="btn btn-outline">+ Agendar nueva</a>
</div>

@if (!Model.Any())
{
    <div class="card" style="text-align:center;padding:3rem">
        <div style="font-size:2.5rem;margin-bottom:1rem">📅</div>
        <div class="card-title">Aún no tienes sesiones agendadas</div>
        <div class="card-sub">Explora nuestras mentoras verificadas y agenda tu primera sesión</div>
        <a asp-action="Index" class="btn btn-primary" style="margin-top:1rem">Ver mentoras →</a>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:1rem">
        @foreach (var sesion in Model)
        {
            <div class="card">
                <div class="row-between">
                    <div style="display:flex;align-items:center;gap:0.9rem">
                        <div style="width:44px;height:44px;border-radius:50%;background:var(--purple);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:0.9rem;flex-shrink:0">
                            @sesion.Mentora.Usuario.Nombre.Substring(0, 2).ToUpper()
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:0.95rem">@sesion.Mentora.Usuario.Nombre</div>
                            <div style="font-size:0.78rem;color:var(--ink-soft)">
                                @sesion.Mentora.Especialidad · Para <strong>@sesion.Nina.NombrePila</strong>
                            </div>
                            <div style="font-size:0.75rem;color:var(--ink-soft);margin-top:0.2rem">
                                📅 @sesion.FechaSesion.ToString("dddd dd MMM yyyy · HH:mm") · @sesion.DuracionMinutos min
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem">
                        <span class="badge @(sesion.Estado == "Confirmada" ? "badge-green" : sesion.Estado == "Completada" ? "badge-purple" : sesion.Estado == "Cancelada" ? "badge-red" : "badge-amber")">
                            @sesion.Estado
                        </span>
                        @if (sesion.Tema != null)
                        {
                            <span style="font-size:0.72rem;color:var(--ink-soft)">📚 @sesion.Tema</span>
                        }
                    </div>
                </div>

                @if (sesion.Estado == "Confirmada" || sesion.Estado == "EnCurso")
                {
                    <hr class="divider" />
                    <div style="display:flex;gap:0.5rem">
                        <a asp-controller="Sesiones" asp-action="Sala" asp-route-sesionId="@sesion.SesionId"
                           class="btn btn-primary btn-sm">
                            🎥 Entrar a la sala
                        </a>
                    </div>
                }

                @if (sesion.Estado == "Completada" && sesion.RatingMentora == null)
                {
                    <hr class="divider" />
                    <form method="post" asp-action="Evaluar">
                        <input type="hidden" name="sesionId" value="@sesion.SesionId" />
                        <div style="display:flex;gap:0.7rem;align-items:center;flex-wrap:wrap">
                            <span style="font-size:0.8rem;font-weight:700">¿Cómo estuvo la sesión?</span>
                            <select name="rating" class="form-control" style="width:auto">
                                <option value="5">⭐⭐⭐⭐⭐ Excelente</option>
                                <option value="4">⭐⭐⭐⭐ Muy buena</option>
                                <option value="3">⭐⭐⭐ Buena</option>
                                <option value="2">⭐⭐ Regular</option>
                                <option value="1">⭐ Mala</option>
                            </select>
                            <input type="hidden" name="aprobada" value="true" />
                            <button type="submit" class="btn btn-primary btn-sm">Evaluar</button>
                        </div>
                    </form>
                }

                @if (sesion.RatingMentora != null)
                {
                    <hr class="divider" />
                    <div style="font-size:0.78rem;color:var(--green)">
                        ✅ Evaluada · @sesion.RatingMentora ⭐
                        @if (sesion.Comentario != null)
                        {
                            <span>· "@sesion.Comentario"</span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}