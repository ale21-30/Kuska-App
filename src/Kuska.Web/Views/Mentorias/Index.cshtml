@model IEnumerable<Kuska.Core.Entities.Mentora>
@{
    ViewData["Title"] = "Mentoras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-between" style="margin-bottom:1.8rem">
    <div>
        <div class="section-label">Módulo de Mentorías</div>
        <div class="section-title">Encuentra tu <em>mentora</em></div>
        <div class="section-sub">Mujeres profesionales que inspiran a las niñas del futuro 🌟</div>
    </div>
    <div style="font-size:0.72rem;color:var(--green);font-weight:600;background:var(--green-pale);border:1px solid #86EFAC;border-radius:99px;padding:0.3rem 0.8rem">
        🛡️ Todas verificadas con cédula
    </div>
</div>

<div class="grid-3">
    @foreach (var mentora in Model)
    {
        <div class="card">
            <div style="display:flex;align-items:center;gap:0.8rem;margin-bottom:0.8rem">
                <div style="width:42px;height:42px;border-radius:50%;background:var(--purple);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:0.9rem;flex-shrink:0">
                    @mentora.Usuario.Nombre.Substring(0, 2).ToUpper()
                </div>
                <div>
                    <div style="font-weight:700;font-size:0.9rem">@mentora.Usuario.Nombre</div>
                    <div style="font-size:0.74rem;color:var(--ink-soft)">@mentora.Especialidad · @mentora.Ciudad</div>
                </div>
            </div>

            <div style="display:flex;flex-wrap:wrap;gap:0.3rem;margin-bottom:0.8rem">
                @foreach (var h in mentora.Habilidades)
                {
                    <span style="padding:0.18rem 0.55rem;background:var(--purple-pale);border:1px solid #C4B5FD;border-radius:99px;font-size:0.68rem;color:var(--purple);font-weight:600">
                        @h.Habilidad
                    </span>
                }
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between">
                <span style="font-size:0.75rem;color:var(--ink-soft)">
                    ⭐ @mentora.Rating.ToString("F1") · @mentora.TotalSesiones sesiones
                </span>
                <a asp-action="Agendar" asp-route-mentoraId="@mentora.MentoraId" class="btn btn-primary">
                    Solicitar sesión
                </a>
            </div>
        </div>
    }
</div>