@model IEnumerable<Kuska.Core.Entities.Nina>
@{
    ViewData["Title"] = "Apadrinar una niña";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cartoons = new[] {
        "🧒","👧","🧒‍♀️","👩‍🎓","🧕","👱‍♀️"
    };
}

<div class="row-between" style="margin-bottom:1.8rem">
    <div>
        <div class="section-label">Programa de Apadrinamiento</div>
        <div class="section-title">Cambia una <em>vida</em></div>
        <div class="section-sub">Cada niña tiene una historia y una lista de útiles concreta — tú eliges a quién apoyar 💜</div>
    </div>
    <div style="display:flex;gap:0.5rem">
        <span class="badge badge-green">@Model.Count() niñas esperando</span>
    </div>
</div>

<!-- STATS -->
<div class="grid-3" style="margin-bottom:2rem">
    <div class="stat-card">
        <div class="stat-number">@Model.Count()</div>
        <div class="stat-label">Niñas registradas</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">@Model.SelectMany(n => n.ListaUtiles).Count(i => i.Cubierto)</div>
        <div class="stat-label">Útiles apadrinados</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">$@Model.SelectMany(n => n.ListaUtiles).Where(i => i.Cubierto).Sum(i => i.PrecioEstimado * i.Cantidad).ToString("N0")</div>
        <div class="stat-label">Invertido en niñas</div>
    </div>
</div>

<!-- GALERÍA -->
<div class="grid-3">
    @{
        int i = 0;
    }
    @foreach (var nina in Model)
    {
        var total = nina.ListaUtiles.Sum(x => x.PrecioEstimado * x.Cantidad);
        var cubierto = nina.ListaUtiles.Where(x => x.Cubierto).Sum(x => x.PrecioEstimado * x.Cantidad);
        var pct = total > 0 ? (int)(cubierto / total * 100) : 0;
        var emoji = cartoons[i % cartoons.Length];
        i++;

        <div class="card" style="display:flex;flex-direction:column;gap:0.8rem">
            <!-- Avatar cartoon -->
            <div style="text-align:center;padding:1rem 0 0.5rem">
                <div style="font-size:3.8rem;line-height:1">@emoji</div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;margin-top:0.3rem">@nina.NombrePila</div>
                <div style="font-size:0.75rem;color:var(--ink-soft)">@nina.Edad años · @nina.AreaInteres</div>
            </div>

            <!-- Historia -->
            @if (nina.Historia != null)
            {
                <div style="font-size:0.82rem;color:var(--ink-mid);text-align:center;font-style:italic;padding:0 0.5rem;line-height:1.5">
                    "@nina.Historia"
                </div>
            }

            <!-- Progreso lista útiles -->
            <div>
                <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:var(--ink-soft);font-weight:600;margin-bottom:0.3rem">
                    <span>Lista de útiles</span>
                    <span style="color:@(pct == 100 ? "var(--green)" : "var(--amber)")">@pct% cubierto</span>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill @(pct == 100 ? "green" : "amber")" style="width:@pct%"></div>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:var(--ink-soft);margin-top:0.3rem">
                    <span>$@cubierto.ToString("N0") cubierto</span>
                    <span>$@total.ToString("N0") total</span>
                </div>
            </div>

            <!-- Items preview -->
            <div style="display:flex;flex-wrap:wrap;gap:0.25rem">
                @foreach (var item in nina.ListaUtiles.Take(3))
                {
                    <span style="font-size:0.68rem;padding:0.15rem 0.5rem;border-radius:99px;background:@(item.Cubierto ? "var(--green-pale)" : "var(--cream)");color:@(item.Cubierto ? "var(--green)" : "var(--ink-soft)");border:1px solid @(item.Cubierto ? "#86EFAC" : "var(--cream-dark)")">
                        @(item.Cubierto ? "✓" : "○") @item.Descripcion
                    </span>
                }
                @if (nina.ListaUtiles.Count() > 3)
                {
                    <span style="font-size:0.68rem;color:var(--ink-soft)">+@(nina.ListaUtiles.Count() - 3) más</span>
                }
            </div>

            <a asp-action="Perfil" asp-route-ninaId="@nina.NinaId"
               class="btn btn-primary" style="width:100%;justify-content:center;margin-top:auto">
                Ver lista y apadrinar →
            </a>
        </div>
    }
</div>