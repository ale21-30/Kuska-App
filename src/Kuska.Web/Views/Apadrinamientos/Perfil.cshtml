@model Kuska.Core.Entities.Nina
@{
    ViewData["Title"] = $"Apadrinar a {Model.NombrePila}";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var total = Model.ListaUtiles.Sum(x => x.PrecioEstimado * x.Cantidad);
    var cubierto = Model.ListaUtiles.Where(x => x.Cubierto).Sum(x => x.PrecioEstimado * x.Cantidad);
    var pct = total > 0 ? (int)(cubierto / total * 100) : 0;
    var cartoons = new[] { "🧒", "👧", "🧒‍♀️", "👩‍🎓" };
    var emoji = cartoons[Model.NinaId % cartoons.Length];
}

<div style="max-width:700px;margin:0 auto">

    <!-- HEADER -->
    <div style="text-align:center;margin-bottom:2rem">
        <div class="section-label">Programa de Apadrinamiento</div>
        <div style="font-size:4.5rem;margin:0.5rem 0">@emoji</div>
        <div class="section-title">@Model.NombrePila</div>
        <div style="font-size:0.82rem;color:var(--ink-soft)">@Model.Edad años · @Model.AreaInteres</div>
        @if (Model.Historia != null)
        {
            <div style="font-size:0.9rem;color:var(--ink-mid);font-style:italic;margin-top:0.8rem;max-width:480px;margin-left:auto;margin-right:auto;line-height:1.6">
                "@Model.Historia"
            </div>
        }
    </div>

    <!-- PROGRESO GENERAL -->
    <div class="card" style="background:linear-gradient(135deg,#F3EEFF,#FDFCFF);border-color:#D4B8F0;margin-bottom:1.2rem;text-align:center">
        <div style="font-size:0.68rem;color:var(--ink-soft);text-transform:uppercase;letter-spacing:1px;font-weight:700">Total de la lista</div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:600;color:var(--purple)">
            $@cubierto.ToString("N0") <span style="font-size:1.2rem;color:var(--ink-soft)">/ $@total.ToString("N0")</span>
        </div>
        <div class="progress-bar" style="margin:0.6rem 0">
            <div class="progress-fill @(pct == 100 ? "green" : "amber")" style="width:@pct%"></div>
        </div>
        <div style="font-size:0.78rem;color:@(pct == 100 ? "var(--green)" : "var(--amber)");font-weight:700">
            @(pct == 100 ? "✅ Lista completamente cubierta" : $"{pct}% cubierto — faltan ${(total - cubierto).ToString("N0")}")
        </div>
    </div>

    <!-- LISTA DE ÚTILES -->
    <div class="card" style="margin-bottom:1.2rem">
        <div class="card-title">Lista de útiles y uniforme</div>
        <div class="card-sub">Selecciona los ítems que quieres apadrinar</div>
        <hr class="divider">

        <form method="post" asp-action="Apadrinar">
            <input type="hidden" name="ninaId" value="@Model.NinaId" />

            <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.2rem">
                @foreach (var item in Model.ListaUtiles)
                {
                    <label style="display:flex;align-items:center;gap:0.8rem;padding:0.7rem 0.9rem;border-radius:10px;border:1px solid @(item.Cubierto ? "#86EFAC" : "var(--cream-dark)");background:@(item.Cubierto ? "var(--green-pale)" : "white");cursor:@(item.Cubierto ? "default" : "pointer")">
                        @if (item.Cubierto)
                        {
                            <span style="font-size:1.1rem">✅</span>
                        }
                        else
                        {
                            <input type="checkbox" name="itemIds" value="@item.ItemId"
                                   style="width:16px;height:16px;accent-color:var(--purple)" />
                        }
                        <div style="flex:1">
                            <div style="font-size:0.85rem;font-weight:@(item.Cubierto ? "400" : "600");color:@(item.Cubierto ? "var(--ink-soft)" : "var(--ink)")">
                                @item.Descripcion
                                @if (item.Cantidad > 1)
                                {
                                    <span style="font-size:0.72rem;color:var(--ink-soft)">× @item.Cantidad</span>
                                }
                            </div>
                            @if (item.Cubierto && item.Apadrinador != null)
                            {
                                <div style="font-size:0.7rem;color:var(--green)">Apadrinado por @item.Apadrinador.Nombre</div>
                            }
                        </div>
                        <div style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:@(item.Cubierto ? "var(--ink-soft)" : "var(--purple)")">
                            $@((item.PrecioEstimado * item.Cantidad).ToString("N2"))
                        </div>
                    </label>
                }
            </div>

            @if (Model.ListaUtiles.Any(x => !x.Cubierto))
            {
                <div class="info-box info-purple" style="margin-bottom:1rem">
                    🛡️ Solo verás el <strong>nombre de pila y edad</strong> de la niña. Nunca datos de contacto ni ubicación exacta. Cumplimos con la LOPDP Ecuador 2021.
                </div>
                <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:0.65rem;font-size:0.95rem">
                    Apadrinar ítems seleccionados 💜
                </button>
            }
            else
            {
                <div class="info-box info-green" style="margin-bottom:0">
                    🎉 ¡Esta niña ya tiene toda su lista cubierta! Puedes apadrinar a otra niña.
                </div>
            }
        </form>
    </div>

    <!-- APADRINAMIENTOS PREVIOS -->
    @if (Model.Apadrinamientos.Any())
    {
        <div class="card">
            <div class="card-title">Personas y empresas que apoyaron a @Model.NombrePila</div>
            <hr class="divider">
            @foreach (var ap in Model.Apadrinamientos)
            {
                <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid var(--cream-dark);font-size:0.82rem">
                    <span>💜 @ap.Empresa.Nombre</span>
                    <span style="font-weight:700;color:var(--purple)">$@ap.MontoTotal.ToString("N2")</span>
                </div>
            }
        </div>
    }

    <div style="text-align:center;margin-top:1.2rem">
        <a asp-action="Index" class="btn btn-outline">← Ver otras niñas</a>
    </div>
</div>