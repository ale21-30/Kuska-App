<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Kuska</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="nav">
        <div class="nav-top">
            <a asp-controller="Home" asp-action="Index" class="logo-name">Kuska</a>
            <span class="logo-tagline">Juntas hacia el futuro · Ecuador</span>
            @if (Context.Session.GetString("Rol") != null)
            {
                <div class="nav-secure">🔒 @Context.Session.GetString("Nombre")</div>
            }
        </div>
        @if (Context.Session.GetInt32("UsuarioId") != null)
        {
            <div style="display:flex;justify-content:center;border-top:1.5px solid var(--border);">
                <div class="nav-tabs">
                    <a asp-controller="Fondos" asp-action="Index" class="nav-tab">💰 Fondos</a>
                    <a asp-controller="Mentorias" asp-action="Index" class="nav-tab">📅 Mentorías</a>
                    <a asp-controller="Mentorias" asp-action="MisSesiones" class="nav-tab">🎥 Mis Sesiones</a>
                    <a asp-controller="Ninas" asp-action="Crear" class="nav-tab">👧 Mi hija</a>
                    <a asp-controller="Apadrinamientos" asp-action="Index" class="nav-tab">💜 Apadrinar</a>
                    @if (Context.Session.GetString("Rol") == "Admin")
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="nav-tab">📊 Dashboard</a>
                    }
                    @if (Context.Session.GetString("Rol") == "Empresa")
                    {
                        <a asp-controller="Empresa" asp-action="Index" class="nav-tab">🏢 Mi Panel</a>
                    }
                    <a asp-controller="Auth" asp-action="Logout" class="nav-tab">Salir</a>
                </div>
            </div>
        }
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <div class="watermark">Kuska · Ecuador 2026</div>

</body>
</html>